# Copy this file to .env. Never commit the resulting .env file.
#
# Required: use a unique random value, for example: openssl rand -hex 32
# This intentionally has no usable default.
TRACEBAG_POSTGRES_PASSWORD=

# Required when authentication is enabled. This is an ASP.NET Core Identity
# password hash, not a plaintext password. Generate one as described in the
# quickstart. This intentionally has no usable default.
TRACEBAG_ADMIN_PASSWORD_HASH=
TRACEBAG_ADMIN_USER=admin
TRACEBAG_AUTH_ENABLED=true
# Per-client login budget. Direct clients use their source IP; forwarded client
# addresses are honored only from the literal proxies/networks listed below.
TRACEBAG_AUTH_LOGIN_PERMIT_LIMIT=5
TRACEBAG_AUTH_LOGIN_WINDOW_SECONDS=60
TRACEBAG_TRUSTED_PROXIES=

# Audit events are retained in PostgreSQL for at most this age and count.
TRACEBAG_AUDIT_RETENTION_DAYS=30
TRACEBAG_AUDIT_MAX_EVENTS=100000
TRACEBAG_AUDIT_RETENTION_DELETE_BATCH_SIZE=1000
TRACEBAG_AUDIT_RETENTION_SCAN_SECONDS=300
TRACEBAG_DIAGNOSTIC_JOB_RETENTION_DAYS=30
TRACEBAG_DIAGNOSTIC_JOB_RETENTION_DELETE_BATCH_SIZE=100
TRACEBAG_DURABLE_RETENTION_SCAN_SECONDS=300
# Incidents never expire automatically. Creation stops at this count until an
# operator exports and explicitly deletes one.
TRACEBAG_INCIDENT_MAX_COUNT=200

# The application is private to this host unless you deliberately change this.
TRACEBAG_BIND_ADDRESS=127.0.0.1
TRACEBAG_PORT=9090
TRACEBAG_PUBLIC_URL=http://localhost:9090
TRACEBAG_STAGE=local

# Development image names built from this repository.
TRACEBAG_IMAGE=tracebag:dev
TRACEBAG_RUNNER_IMAGE_DOTNET_8=tracebag-runner-dotnet-8:dev
TRACEBAG_RUNNER_IMAGE_DOTNET_9=tracebag-runner-dotnet-9:dev
TRACEBAG_RUNNER_IMAGE_DOTNET_10=tracebag-runner-dotnet-10:dev
TRACEBAG_RUNNER_DEFAULT_RUNTIME_MAJOR=8
TRACEBAG_RUNNER_MEMORY_LIMIT_BYTES=1073741824
TRACEBAG_RUNNER_CPU_LIMIT_MILLICORES=1000
TRACEBAG_RUNNER_PIDS_LIMIT=128

# Docker volumes. The artifact name must match the name given to temporary
# diagnostic runners, so do not change it on an existing installation.
TRACEBAG_ARTIFACT_VOLUME=tracebag_artifacts
TRACEBAG_DATA_VOLUME=tracebag_data
TRACEBAG_POSTGRES_VOLUME=tracebag_postgres

# Optional demo API. It is also localhost-only and resource-bounded.
TRACEBAG_DEMO_IMAGE=tracebag-demo-api:dev
TRACEBAG_DEMO_BIND_ADDRESS=127.0.0.1
TRACEBAG_DEMO_PORT=9091
TRACEBAG_DEMO_DOTNET_TMP_VOLUME=tracebag_demo_dotnet_tmp
TRACEBAG_DEMO_FULL_DUMP_ENABLED=false
TRACEBAG_DEMO_TRAFFIC_INTERVAL_MS=1000

# A container is invisible unless it explicitly has this label.
TRACEBAG_ALLOWED_LABEL=tracebag.enabled=true
# Optional second label expression, such as tracebag.environment=production.
TRACEBAG_ENVIRONMENT_LABEL=

# Container restart remains disabled unless both this and the target label are true.
TRACEBAG_RESTART_ENABLED=false

# Bounded diagnostic and retention defaults.
TRACEBAG_COUNTER_MAX_SECONDS=600
TRACEBAG_DIAGNOSTIC_JOB_MAX_ACTIVE_GLOBAL=2
TRACEBAG_DIAGNOSTIC_JOB_DAILY_LIMIT=25
TRACEBAG_DIAGNOSTIC_JOB_MAX_DURATION_SECONDS=600
# Full dumps also require tracebag.diagnostics.fullDump=true on the target and
# exact confirmation in each request. Leave this false unless explicitly needed.
TRACEBAG_FULL_DUMP_ENABLED=false
# Local analysis reads only registered incident artifacts and stops at these limits.
TRACEBAG_ANALYSIS_MAX_TRACE_BYTES=536870912
TRACEBAG_ANALYSIS_MAX_STACK_BYTES=8388608
TRACEBAG_ANALYSIS_MAX_EVENTS=2000000
TRACEBAG_COUNTER_RECORDING_ENABLED=true
TRACEBAG_COUNTER_RECORDING_DEFAULT_INTERVAL_SECONDS=5
TRACEBAG_COUNTER_RECORDING_MAX_DURATION_MINUTES=1440
TRACEBAG_COUNTER_RECORDING_MAX_ACTIVE_GLOBAL=3
TRACEBAG_COUNTER_RECORDING_RETENTION_DAYS=7
TRACEBAG_LOG_INGESTION_ENABLED=true
TRACEBAG_LOG_CHANNEL_CAPACITY=5000
TRACEBAG_LOG_BATCH_SIZE=200
TRACEBAG_LOG_FLUSH_MILLISECONDS=1000
TRACEBAG_LOG_COLLECTOR_SCAN_SECONDS=5
TRACEBAG_LOG_RETENTION_DAYS=7
TRACEBAG_LOG_MAX_TOTAL_BYTES=1073741824
TRACEBAG_LOG_MAX_BYTES_PER_CONTAINER=268435456
TRACEBAG_LOG_RETENTION_DELETE_BATCH_SIZE=1000
TRACEBAG_LOG_RETENTION_SCAN_SECONDS=60
TRACEBAG_LOG_MAX_LINE_BYTES=262144
TRACEBAG_ARTIFACT_RETENTION_HOURS=24
TRACEBAG_ARTIFACT_MAX_COUNT=20
TRACEBAG_ARTIFACT_MAX_TOTAL_BYTES=2147483648
