# -----------------------------------------------------------------------------
# Local development archive
# -----------------------------------------------------------------------------
# Planning documents, development histories, retired prototypes, and internal
# verification evidence live here and are never part of a release checkout.
/archive/

# -----------------------------------------------------------------------------
# Operating system files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Editors and IDEs
# -----------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.code-workspace
*.swp
*.swo
*~

# JetBrains Rider
*.sln.iml

# -----------------------------------------------------------------------------
# .NET build and test output
# -----------------------------------------------------------------------------
**/bin/
**/obj/
**/publish/
**/TestResults/
**/BenchmarkDotNet.Artifacts/
/artifacts/
/supply-chain-evidence/

*.nupkg
*.snupkg
*.deps.json
*.runtimeconfig.dev.json

# Keep intentional runtimeconfig files if they are ever added as source.
!**/Properties/*.json

# .NET coverage and profiling output
coverage/
coverage-*/
*.coverage
*.coveragexml
*.coverlet.json
*.opencover.xml
*.cobertura.xml
*.trx
*.diagsession
*.nettrace
*.gcdump
*.dmp
*.speedscope.json

