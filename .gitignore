appsettings.Local.json
appsettings.*.Local.json
secrets/
**/secrets/

*.pfx
*.p12
*.jks
*.keystore
*.pem
*.key

# ASP.NET Core user-secrets are normally outside the repository, but ignore a
# local copy if one is mounted during development.
.microsoft/usersecrets/

