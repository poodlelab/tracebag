---
import Brand from './Brand.astro';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const nav = [
  { label: 'How it works', href: `${base}#features` },
  { label: 'Demo', href: `${base}demo/` },
  { label: 'Docs', href: `${base}docs/` },
  { label: 'Security', href: `${base}security/` },
];
---

<header class="site-header">
  <div class="shell header-inner">
    <Brand compact />
    <nav aria-label="Main navigation">
      {nav.map((item) => (
        <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>
    <a class="button button-small desktop-cta" href="https://github.com/poodlelab/tracebag">View on GitHub</a>
  </div>
</header>
