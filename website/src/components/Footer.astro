---
const base = import.meta.env.BASE_URL;
---

<footer>
  <div class="shell footer-grid">
    <div class="footer-summary">
      <strong>Tracebag</strong>
      <p>Open-source debugging for Dockerized .NET applications.</p>
    </div>
    <div>
      <h2>Product</h2>
      <a href={`${base}getting-started/`}>Get started</a>
      <a href={`${base}demo/`}>Demo</a>
      <a href={`${base}security/`}>Security</a>
    </div>
    <div>
      <h2>Project</h2>
      <a href="https://github.com/poodlelab/tracebag">GitHub</a>
      <a href="https://github.com/poodlelab/tracebag/releases">Releases</a>
      <a href="https://github.com/poodlelab/tracebag/blob/main/CONTRIBUTING.md">Contribute</a>
    </div>
  </div>
  <div class="shell footer-bottom">
    <span>Apache-2.0</span>
    <a href={`${base}development/`}>Human-directed, AI-assisted development.</a>
  </div>
</footer>
